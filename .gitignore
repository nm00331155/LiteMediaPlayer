.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# ------------------------------------------------------------
