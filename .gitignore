# ------------------------------------------------------------
*.class

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Kotlin Gradle plugin data
.kotlin/
.kotlinc/

# ------------------------------------------------------------
# Gradle / Android build outputs
# ------------------------------------------------------------
.gradle/

# Build folders (root + modules)
build/
**/build/

# Android generated folders
captures/
.externalNativeBuild/
.cxx/

# Local SDK path (machine-specific)
local.properties

# APK / AAB / packaged artifacts
*.apk
*.aab
*.ap_
*.aar

# Native / profiling artifacts
*.hprof

# ------------------------------------------------------------
# Logs / reports
# ------------------------------------------------------------
*.log
hs_err_pid*
replay_pid*

