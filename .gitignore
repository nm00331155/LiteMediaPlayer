# ------------------------------------------------------------
.env
.env.*
!.env.example

*.keystore
*.jks
*.p12
*.pfx
*.pem

# Common cloud/mobile secret config files
google-services.json
firebase-service-account*.json

# ------------------------------------------------------------
# Python helper script artifacts (if used in this repo)
# ------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/

